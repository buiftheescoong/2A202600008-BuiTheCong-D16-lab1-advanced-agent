# OpenAI API Configuration
# Điền API key của bạn vào đây (lấy tại https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# Model cho Actor (dùng model YẾU để chứng minh tác dụng của Reflexion)
# gpt-3.5-turbo: rẻ, hay sai multi-hop → Reflexion có cơ hội cải thiện
ACTOR_MODEL=gpt-3.5-turbo

# Model cho Evaluator + Reflector (cần trả JSON chuẩn, phân tích lỗi tốt)
# gpt-4o-mini: rẻ hơn gpt-4o nhưng vẫn đủ tốt cho chấm điểm + phản chiếu
EVAL_MODEL=gpt-4o-mini
# ---- Rate limit protection ----
INTER_CALL_DELAY=0.5
# Số lần retry tối đa khi bị rate limit
MAX_RETRIES=5
# Base delay cho exponential backoff: lần 1=2s, lần 2=4s, lần 3=8s...
BACKOFF_BASE=2.0
